# ============================================================
# DBSN Environment Configuration
# ============================================================
# Current Deployment: Vercel (dbsn-test01.vercel.app — Development Phase)
# Planned Production: Cloudflare Pages (dayaberkah.id)
# ============================================================

# Supabase Database Configuration
SUPABASE_ACCESS_TOKEN=your_supabase_access_token
SUPABASE_PROJECT_REF=your_supabase_project_ref

# GitHub Configuration
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token

# Sanity CMS Configuration
# Get your project ID from https://www.sanity.io/manage
SANITY_PROJECT_ID=your_project_id
# Dataset name (typically "production" for production, "development" for dev)
SANITY_DATASET=production
# API version (use current date format: vYYYY-MM-DD)
SANITY_API_VERSION=v2025-05-21
# Read-only API token (get from Sanity dashboard: API > Tokens)
# Required for server-side fetching with ISR tags
SANITY_API_READ_TOKEN=your_read_only_token
# Write API token (optional, for administrative operations)
# SANITY_API_WRITE_TOKEN=your_write_token

# MCP Server Configuration
# Enable/disable specific MCP servers by uncommenting these lines
SUPABASE_DISABLE=false
GITHUB_DISABLE=false
CONTEXT7_DISABLE=false
FILESYSTEM_DISABLE=false
SEQUENTIAL_THINKING_DISABLE=false
PLAYWRIGHT_DISABLE=false

# Database Configuration
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Auth.js Configuration
NEXTAUTH_SECRET=your-secret-min-32-characters-long
# Local Dev Default: http://lvh.me:3000
# Vercel Staging: https://dbsn-test01.vercel.app
# Cloudflare Pages Production: https://dayaberkah.id
NEXTAUTH_URL=http://lvh.me:3000

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Notification Configuration
RESEND_API_KEY=re_your_api_key_placeholder
RESEND_FROM_EMAIL=onboarding@resend.dev
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_placeholder
TELEGRAM_CHAT_ID=-1001234567890
WHATSAPP_SALES_NUMBER=6281234567890

# Google Search Console (GSC) Configuration
NEXT_PUBLIC_GSC_VERIFICATION=your_gsc_meta_tag_verification_token
GSC_VERIFICATION_CODE=google123456789.html
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----","client_email":"your-service-account@your-project.iam.gserviceaccount.com"}

# === Sentry Error Tracking ===
NEXT_PUBLIC_SENTRY_DSN=https://[dsn]@sentry.io/[project-id]
SENTRY_AUTH_TOKEN=[your-auth-token]
SENTRY_ORG=pt-daya-berkah-sentosa-nusanta
SENTRY_PROJECT=javascript-nextjs

# === PostHog Analytics ===
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# === Google Analytics (Ensure filled for production) ===
NEXT_PUBLIC_GA_TRACKING_ID=G-[XXXXXXXXX]
GA_TRACKING_ID=G-[XXXXXXXXX]

# === Production Database ===
# DATABASE_URL configuration is already defined above

# === Sanity CMS (Optional for admin operations) ===
SANITY_API_WRITE_TOKEN=[your-write-token]
SANITY_WEBHOOK_SECRET=[your-webhook-secret]